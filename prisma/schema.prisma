generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActionType {
  decision_complete
  go_call
  go_directions
  go_website
  open_actor
  challenge_complete
}

enum ItemType {
  phone
  laptop
  tablet
  desktop
  smartwatch
  tv
  monitor
  printer
  camera
  gaming_console
  audio
  small_appliance
  large_appliance
  bicycle
  furniture
  clothing
  footwear
  other
}

enum ProblemType {
  screen
  battery
  slow
  no_power
  water
  overheating
  charging_port
  speaker
  microphone
  camera
  keyboard
  trackpad
  storage
  software
  connectivity
  broken_part
  cosmetic
  noise
  leak
  motor
  zipper
  seam
  tear
  stain
  sole
  chain
  brake
  tire
  wheel
  other
}

enum Priority {
  save_money
  save_time
  save_impact
  balanced
}

enum Recommendation {
  repair
  buy_used
  donate
  recycle
}

enum DecisionStatus {
  feasible
  not_fully_feasible
}

enum ConfidenceLevel {
  low
  medium
  high
}

enum ActorCategory {
  brukt
  reparasjon
  gjenvinning
  utleie
  reparasjon_sko_klar
  mottak_ombruk
  mobelreparasjon
  sykkelverksted
  ombruksverksted
  baerekraftig_mat
}

enum ActorStatus {
  pending
  approved
  rejected
  archived
}

enum SourceType {
  website
  social
  google_reviews
  article
  map
}

enum UserRole {
  user
  admin
}

enum QuizLevel {
  starter
  pa_vei
  gjenbrukshelt
}

enum VerificationStatus {
  unverified
  community_verified
  editorial_verified
}

enum VerificationDueState {
  healthy
  due_soon
  due
  overdue
  blocked
}

enum ActorImportBatchStatus {
  preview
  applied
  failed
}

enum ActorImportMatchStrategy {
  slug
  website_host
  name_postal
  none
}

enum ActorImportAction {
  create
  update
  skip
  error
}

enum ActorImportRowType {
  actor
  actor_source
  actor_repair_service
}

enum ActorCorrectionStatus {
  pending
  accepted
  rejected
}

enum ActorVerificationTaskStatus {
  open
  snoozed
  resolved
}

enum CountyRolloutStage {
  pilot
  queued
  in_progress
  ready
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  imageUrl  String?  @map("image_url")
  role      UserRole @default(user)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile              UserProfile?
  actions              UserAction[]
  decisions            Decision[]
  challengeCompletions ChallengeCompletion[]
  quizAttempts         QuizAttempt[]
  actorsCreated        Actor[] @relation("ActorCreatedBy")
  actorsReviewed       Actor[] @relation("ActorReviewedBy")
  favoriteActors       ActorFavorite[]
  importBatchesCreated ActorImportBatch[] @relation("ActorImportBatchCreatedBy")
  correctionsSubmitted ActorCorrectionSuggestion[] @relation("ActorCorrectionSuggestionSubmittedBy")
  correctionsReviewed  ActorCorrectionSuggestion[] @relation("ActorCorrectionSuggestionReviewedBy")
  resolvedVerificationTasks ActorVerificationTask[] @relation("ActorVerificationTaskResolvedBy")

  @@map("users")
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  score          Int      @default(0)
  streakDays     Int      @default(0) @map("streak_days")
  lastActionDate DateTime? @map("last_action_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserAction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      ActionType
  points    Int      @default(0)
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_actions")
}

model Decision {
  id                     String           @id @default(cuid())
  userId                 String           @map("user_id")
  itemType               ItemType         @map("item_type")
  problemType            ProblemType      @map("problem_type")
  recommendation         Recommendation
  priority               Priority?
  status                 DecisionStatus?
  confidence             ConfidenceLevel?
  recommendedFeasible    Boolean?         @map("recommended_feasible")
  bestFeasibleOption     Recommendation?  @map("best_feasible_option")
  budgetNok              Int              @map("budget_nok")
  timeDays               Int              @map("time_days")
  modelRepairabilityScore Float?          @map("model_repairability_score")
  impactScore            Float            @map("impact_score")
  savingsMin             Float            @map("savings_min")
  savingsMax             Float            @map("savings_max")
  co2eSavedMin           Float?           @map("co2e_saved_min")
  co2eSavedMax           Float?           @map("co2e_saved_max")
  explainability         Json?
  options                Json?
  planB                  Json?            @map("plan_b")
  createdAt              DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("decisions")
}

model ChallengeCompletion {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  points      Int
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId, createdAt])
  @@map("challenge_completions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  score     Int
  maxScore  Int      @map("max_score")
  level     QuizLevel
  answers   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("quiz_attempts")
}

model County {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  municipalities   Municipality[]
  baseActors       Actor[]           @relation("ActorBaseCounty")
  actorServiceAreas ActorServiceArea[]
  rolloutStatus    CountyRolloutStatus?

  @@index([sortOrder, name])
  @@map("counties")
}

model Municipality {
  id        String   @id @default(cuid())
  countyId  String   @map("county_id")
  slug      String
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  county             County           @relation(fields: [countyId], references: [id], onDelete: Cascade)
  baseActors         Actor[]          @relation("ActorBaseMunicipality")
  actorServiceAreas  ActorServiceArea[]

  @@unique([countyId, slug])
  @@unique([countyId, name])
  @@index([slug])
  @@index([countyId, sortOrder, name])
  @@map("municipalities")
}

model Actor {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  category        ActorCategory
  description     String
  longDescription String       @map("long_description")
  address         String
  postalCode      String?      @map("postal_code")
  country         String       @default("Norway")
  county          String?
  countySlug      String?      @map("county_slug")
  municipality    String?
  municipalitySlug String?     @map("municipality_slug")
  city            String?
  area            String?
  lat             Float
  lng             Float
  phone           String?
  email           String?
  website         String?
  instagram       String?
  openingHours    String[]     @map("opening_hours")
  openingHoursOsm String?      @map("opening_hours_osm")
  tags            String[]
  benefits        String[]
  howToUse        String[]     @map("how_to_use")
  image           String?      @map("image_url")
  nationwide      Boolean      @default(false)
  baseCountyId    String?      @map("base_county_id")
  baseMunicipalityId String?   @map("base_municipality_id")
  verificationStatus VerificationStatus @default(unverified) @map("verification_status")
  verifiedAt      DateTime?    @map("verified_at")
  status          ActorStatus  @default(pending)
  reviewNote      String?      @map("review_note")
  createdById     String?      @map("created_by_id")
  reviewedById    String?      @map("reviewed_by_id")
  reviewedAt      DateTime?    @map("reviewed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  createdBy  User? @relation("ActorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedBy User? @relation("ActorReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  baseCounty County? @relation("ActorBaseCounty", fields: [baseCountyId], references: [id], onDelete: SetNull)
  baseMunicipality Municipality? @relation("ActorBaseMunicipality", fields: [baseMunicipalityId], references: [id], onDelete: SetNull)

  repairServices ActorRepairService[]
  sources        ActorSource[]
  favorites      ActorFavorite[]
  serviceAreas   ActorServiceArea[]
  correctionSuggestions ActorCorrectionSuggestion[]
  matchedImportRows     ActorImportRow[]
  verificationTasks     ActorVerificationTask[]

  @@index([status, category])
  @@index([status, countySlug, municipalitySlug, category])
  @@index([status, baseCountyId, baseMunicipalityId, category])
  @@index([status, city, category])
  @@index([status, nationwide])
  @@index([createdById, createdAt])
  @@map("actors")
}

model ActorFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  actorId   String   @map("actor_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([userId, actorId])
  @@index([userId, createdAt])
  @@index([actorId])
  @@map("actor_favorites")
}

model ActorRepairService {
  id          String      @id @default(cuid())
  actorId     String      @map("actor_id")
  problemType ProblemType @map("problem_type")
  itemTypes   ItemType[]  @map("item_types")
  priceMin    Int         @map("price_min")
  priceMax    Int         @map("price_max")
  etaDays     Int?        @map("eta_days")

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@map("actor_repair_services")
}

model ActorSource {
  id         String     @id @default(cuid())
  actorId    String     @map("actor_id")
  type       SourceType
  title      String
  url        String
  capturedAt DateTime?  @map("captured_at")
  note       String?

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@map("actor_sources")
}

model ActorServiceArea {
  id             String   @id @default(cuid())
  actorId        String   @map("actor_id")
  countyId       String?  @map("county_id")
  municipalityId String?  @map("municipality_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  actor        Actor        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  county       County?      @relation(fields: [countyId], references: [id], onDelete: Cascade)
  municipality Municipality? @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@unique([actorId, countyId])
  @@unique([actorId, municipalityId])
  @@index([actorId])
  @@index([countyId])
  @@index([municipalityId])
  @@map("actor_service_areas")
}

model ActorImportBatch {
  id            String                 @id @default(cuid())
  filename      String
  status        ActorImportBatchStatus @default(preview)
  targetCounties String[]              @map("target_counties")
  totalRows     Int                    @default(0) @map("total_rows")
  createCount   Int                    @default(0) @map("create_count")
  updateCount   Int                    @default(0) @map("update_count")
  skipCount     Int                    @default(0) @map("skip_count")
  errorCount    Int                    @default(0) @map("error_count")
  warningCount  Int                    @default(0) @map("warning_count")
  errorSummary  Json?                  @map("error_summary")
  createdById   String?                @map("created_by_id")
  createdAt     DateTime               @default(now()) @map("created_at")
  appliedAt     DateTime?              @map("applied_at")

  createdBy User?            @relation("ActorImportBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  rows      ActorImportRow[]

  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@map("actor_import_batches")
}

model ActorImportRow {
  id               String                   @id @default(cuid())
  batchId          String                   @map("batch_id")
  rowType          ActorImportRowType       @map("row_type")
  rowNumber        Int                      @map("row_number")
  rawData          Json                     @map("raw_data")
  normalizedData   Json?                    @map("normalized_data")
  matchStrategy    ActorImportMatchStrategy? @map("match_strategy")
  matchedActorId   String?                  @map("matched_actor_id")
  action           ActorImportAction
  validationErrors String[]                @map("validation_errors")
  warnings         String[]
  appliedAt        DateTime?                @map("applied_at")
  createdAt        DateTime                 @default(now()) @map("created_at")

  batch        ActorImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedActor Actor?           @relation(fields: [matchedActorId], references: [id], onDelete: SetNull)

  @@index([batchId, rowType, rowNumber])
  @@index([action])
  @@index([matchedActorId])
  @@map("actor_import_rows")
}

model ActorCorrectionSuggestion {
  id            String                @id @default(cuid())
  actorId        String                @map("actor_id")
  submittedById  String                @map("submitted_by_id")
  payload        Json
  note           String
  sourceUrl      String?               @map("source_url")
  status         ActorCorrectionStatus @default(pending)
  reviewNote     String?               @map("review_note")
  reviewedById   String?               @map("reviewed_by_id")
  reviewedAt     DateTime?             @map("reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  actor       Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)
  submittedBy User  @relation("ActorCorrectionSuggestionSubmittedBy", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy  User? @relation("ActorCorrectionSuggestionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([actorId, status, createdAt])
  @@index([submittedById, createdAt])
  @@index([reviewedById, reviewedAt])
  @@map("actor_correction_suggestions")
}

model ActorVerificationTask {
  id             String                      @id @default(cuid())
  actorId        String                      @map("actor_id")
  dueState       VerificationDueState        @map("due_state")
  status         ActorVerificationTaskStatus @default(open)
  reasonSummary  String                      @map("reason_summary")
  generatedAt    DateTime                    @map("generated_at")
  snoozeUntil    DateTime?                   @map("snooze_until")
  resolvedAt     DateTime?                   @map("resolved_at")
  resolvedById   String?                     @map("resolved_by_id")
  resolutionNote String?                     @map("resolution_note")
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")

  actor      Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ActorVerificationTaskResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([actorId, status, generatedAt])
  @@index([status, dueState, snoozeUntil])
  @@index([resolvedById, resolvedAt])
  @@map("actor_verification_tasks")
}

model CountyRolloutStatus {
  countyId                String             @id @map("county_id")
  stage                   CountyRolloutStage @default(queued)
  priority                Int                @default(100)
  targetApprovedActors    Int                @default(4) @map("target_approved_actors")
  targetMunicipalities    Int                @default(1) @map("target_municipalities")
  notes                   String?
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  county County @relation(fields: [countyId], references: [id], onDelete: Cascade)

  @@index([stage, priority])
  @@map("county_rollout_statuses")
}

model Challenge {
  id          String        @id @default(cuid())
  key         String        @unique
  title       String
  description String
  points      Int
  icon        String
  category    ActorCategory
  sortOrder   Int           @default(0) @map("sort_order")

  completions ChallengeCompletion[]

  @@index([category, sortOrder])
  @@map("challenges")
}

model QuizQuestion {
  id        String @id @default(cuid())
  key       String @unique
  question  String
  sortOrder Int    @default(0) @map("sort_order")
  options   QuizOption[]

  @@map("quiz_questions")
}

model QuizOption {
  id         String @id @default(cuid())
  questionId String @map("question_id")
  text       String
  points     Int
  sortOrder  Int    @default(0) @map("sort_order")

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, sortOrder])
  @@map("quiz_options")
}

model QuizResult {
  id          String    @id @default(cuid())
  level       QuizLevel @unique
  title       String
  description String
  tips        String[]
  badge       String

  @@map("quiz_results")
}

model RepairEstimate {
  id           String     @id @default(cuid())
  itemType     ItemType   @map("item_type")
  problemType  ProblemType @map("problem_type")
  deviceType   String     @map("device_type")
  issue        String
  repairCostMin Int       @map("repair_cost_min")
  repairCostMax Int       @map("repair_cost_max")
  repairDays    Int       @map("repair_days")
  usedPriceMin  Int       @map("used_price_min")
  usedPriceMax  Int       @map("used_price_max")
  newPrice      Int       @map("new_price")
  co2Saved      Int       @map("co2_saved")

  @@unique([itemType, problemType])
  @@map("repair_estimates")
}

model Fact {
  id          String @id @default(cuid())
  key         String @unique
  title       String
  stat        String
  description String
  icon        String
  sortOrder   Int    @default(0) @map("sort_order")

  @@index([sortOrder])
  @@map("facts")
}

model DetailedFact {
  id        String   @id @default(cuid())
  key       String   @unique
  category  String
  title     String
  icon      String
  content   String[]
  tips      String[]
  sortOrder Int      @default(0) @map("sort_order")

  sources DetailedFactSource[]

  @@index([sortOrder])
  @@map("detailed_facts")
}

model DetailedFactSource {
  id            String @id @default(cuid())
  detailedFactId String @map("detailed_fact_id")
  name          String
  url           String
  sortOrder     Int    @default(0) @map("sort_order")

  detailedFact DetailedFact @relation(fields: [detailedFactId], references: [id], onDelete: Cascade)

  @@index([detailedFactId, sortOrder])
  @@map("detailed_fact_sources")
}

model Co2eSource {
  id         String   @id @default(cuid())
  key        String   @unique
  title      String
  url        String
  capturedAt DateTime? @map("captured_at")
  anchors    String[]

  items Co2eSourceItem[]

  @@map("co2e_sources")
}

model Co2eSourceItem {
  id        String   @id @default(cuid())
  sourceId  String   @map("source_id")
  itemType  ItemType @map("item_type")

  source Co2eSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, itemType])
  @@index([itemType])
  @@map("co2e_source_items")
}
